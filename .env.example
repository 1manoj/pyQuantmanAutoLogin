# Twilio Credentials (for WhatsApp/SMS notifications)
# Required only if notification_settings are enabled in config.json
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+14155238886
NOTIFICATION_PHONE_NUMBER=+919876543210

# Flattrade API Details (Optional, if filling API details on Quantman)
FLATTRADE_API_KEY=your_flattrade_api_key_here
FLATTRADE_API_SECRET=your_flattrade_api_secret_here

# GitHub Personal Access Token (for session state persistence)
# Used by the script to check and upload login status files.
GH_PAT=github_pat_your_token_here
